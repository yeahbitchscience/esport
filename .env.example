# Environment configuration for the Polymarket Esports Anomaly Bot
# Copy this to .env and fill in your values

# Required: Discord webhook URL for anomaly alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1484367907029778432/OJUKZtVitPwrIAODGmUy8F3IOR3KPXvSTN2zOQw0RSR6rU4iVxJITjToI5YwCJ9zEolV

# Optional: Separate webhook for health/crash alerts (defaults to main webhook)
# DISCORD_ERROR_WEBHOOK_URL=

# Polling interval in seconds (default: 300 = 5 minutes)
# POLL_INTERVAL_SECONDS=300

# Minimum anomaly score (0-100) to trigger a Discord alert (default: 40)
# ALERT_SCORE_THRESHOLD=40

# Hours before re-alerting the same market (default: 24)
# DEDUP_HOURS=24

# Maximum price for cheap side detection (default: 0.10)
# CHEAP_SIDE_THRESHOLD=0.10

# Hours of time drift threshold (default: 1.0)
# TIME_MISMATCH_HOURS=1.0

# Liquipedia cache TTL in seconds (default: 21600 = 6 hours)
# LIQUIPEDIA_CACHE_TTL=21600

# Required by Liquipedia TOS - identify your bot
# LIQUIPEDIA_USER_AGENT=PolymarketEsportsBot/1.0 (contact: you@example.com)

# Database path (default: data/bot.db)
# DB_PATH=data/bot.db

# Log directory (default: logs)
# LOG_DIR=logs
